# Frontend Environment Variables - Development Proxy

# Environment
NODE_ENV=development
ENVIRONMENT=development

# API Configuration
API_BASE_URL=http://localhost:3000
API_ENDPOINT=/api/generate-pdf
API_TIMEOUT=30000

# Proxy Configuration (used by ng serve)
PROXY_ENABLED=true
PROXY_TARGET=http://localhost:3000
PROXY_PATH=/api

# Widget Configuration
WIDGET_NAME=exportPdf-widget
WIDGET_VERSION=1.0.0

# Angular Configuration
NG_APP_BUILD_MODE=development
NG_APP_API_URL=/api
